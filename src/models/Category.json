{
  "fields": {
    "id": {
      "type": "Uuid",
      "id": true,
      "default": { "uuid": true }
    },
    "label": { "type": "String" },
    "title": { "type": "String", "unique": true },
    "createdAt": {
      "type": "DateTime",
      "default": { "now": true }
    },
    "updatedAt": {
      "type": "DateTime",
      "default": { "now": true }
    },
    "assets": {
      "type": "Asset[]",
      "relation": { "fields": ["id"], "references": ["categoryId"] }
    }
  }
}
