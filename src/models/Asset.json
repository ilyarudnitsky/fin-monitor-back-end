{
  "fields": {
    "id": {
      "type": "Uuid",
      "id": true,
      "default": { "uuid": true }
    },
    "categoryId": { "type": "Uuid" },
    "name": { "type": "String" },
    "notes": { "type": "String", "optional": true },
    "createdAt": {
      "type": "DateTime",
      "default": { "now": true }
    },
    "updatedAt": {
      "type": "DateTime",
      "default": { "now": true }
    },
    "category": {
      "type": "Category",
      "relation": { "fields": ["categoryId"], "references": ["id"] }
    },
    "investmentAsset": {
      "type": "InvestmentAsset",
      "optional": true,
      "relation": { "fields": ["id"], "references": ["assetId"] }
    },
    "operatingAsset": {
      "type": "OperatingAsset",
      "optional": true,
      "relation": { "fields": ["id"], "references": ["assetId"] }
    },
    "dualPurposeAsset": {
      "type": "DualPurposeAsset",
      "optional": true,
      "relation": { "fields": ["id"], "references": ["assetId"] }
    }
  }
}
